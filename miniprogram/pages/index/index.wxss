/* pages/index/index.wxss */
.font-din {
  font-family: var(--ff-number);
}

.concert-index {
  min-height: 100vh;
  background: var(--color-bg-global, var(--color-bg-page));
}

.concert-index__header {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20rpx 24rpx 22rpx;
  background:
    radial-gradient(circle at 10% -30%, rgba(255, 90, 54, 0.2) 0, rgba(255, 90, 54, 0) 56%),
    radial-gradient(circle at 95% 5%, rgba(0, 194, 168, 0.16) 0, rgba(0, 194, 168, 0) 48%),
    linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg-global, var(--color-bg-page)) 100%);
  border-bottom: 1rpx solid rgba(23, 26, 31, 0.06);
}

.concert-index__search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  background: var(--color-surface);
  box-shadow: var(--shadow-light, var(--shadow-card));
}

.concert-index__search-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-disabled, var(--color-text-muted));
}

.concert-index__search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--color-text-main, var(--color-text-strong));
}

.concert-index__search-placeholder {
  color: var(--color-text-disabled, var(--color-text-muted));
}

.concert-index__search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  color: var(--color-text-disabled, var(--color-text-muted));
  background: rgba(23, 26, 31, 0.05);
}

.concert-index__quick-entry {
  display: flex;
  margin-top: 14rpx;
}

.concert-index__quick-item {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  border-radius: var(--radius-btn);
  border: 1rpx solid rgba(255, 90, 54, 0.2);
  background: rgba(255, 90, 54, 0.12);
  color: var(--color-primary);
}

.concert-index__quick-item:last-child {
  margin-right: 0;
}

.concert-index__quick-item--hot {
  color: var(--color-surface);
  border: none;
  background: linear-gradient(135deg, var(--color-primary) 0%, rgba(255, 90, 54, 0.8) 100%);
  box-shadow: 0 8rpx 18rpx rgba(255, 90, 54, 0.26);
}

.concert-index__quick-item--ghost {
  color: var(--color-accent);
  border-color: rgba(0, 194, 168, 0.25);
  background: rgba(0, 194, 168, 0.12);
}

.concert-index__quick-icon {
  font-size: 22rpx;
  line-height: 1;
  margin-right: 8rpx;
}

.concert-index__quick-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 600;
}

.dev-panel {
  margin: 16rpx 24rpx 8rpx;
  padding: 16rpx;
  border-radius: var(--radius-btn);
  border: 1rpx dashed rgba(255, 90, 54, 0.28);
  background: var(--color-surface);
}

.dev-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dev-panel__title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.dev-panel__btn {
  margin: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  font-size: 23rpx;
  color: var(--color-surface);
  background: var(--color-primary);
}

.dev-panel__btn::after {
  border: none;
}

.dev-panel__result {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--color-text-sub, var(--color-text-body));
  background: rgba(23, 26, 31, 0.03);
  white-space: pre-wrap;
}

.city-filter {
  padding: 14rpx 0 10rpx;
  white-space: nowrap;
}

.city-filter__track {
  display: inline-flex;
  padding: 0 24rpx;
}

.city-filter__item {
  flex-shrink: 0;
  height: 54rpx;
  line-height: 54rpx;
  margin-right: 12rpx;
  padding: 0 24rpx;
  border-radius: 27rpx;
  font-size: 24rpx;
  color: var(--color-text-sub, var(--color-text-body));
  border: 1rpx solid var(--color-border);
  background: var(--color-surface);
}

.city-filter__item:last-child {
  margin-right: 0;
}

.city-filter__item--active {
  color: var(--color-surface);
  border-color: var(--color-primary);
  background: var(--color-primary);
  box-shadow: 0 8rpx 16rpx rgba(255, 90, 54, 0.24);
}

.concert-index__search-tips {
  margin: 0 24rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx dashed var(--color-border);
  font-size: 22rpx;
  color: var(--color-text-disabled, var(--color-text-muted));
  background: var(--color-surface);
}

.concert-index__list {
  padding: 10rpx 24rpx 24rpx;
}

.concert-index__section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 2rpx 14rpx;
}

.concert-index__section-title {
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: var(--color-text-main, var(--color-text-strong));
}

.concert-index__section-count {
  font-size: 22rpx;
  line-height: 32rpx;
  color: var(--color-text-sub, var(--color-text-body));
}

.state-skeleton {
  padding-bottom: 4rpx;
}

.state-skeleton__card {
  display: flex;
  overflow: hidden;
  margin-bottom: 22rpx;
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  background: var(--color-surface);
}

.state-skeleton__poster {
  width: 220rpx;
  height: 294rpx;
  border-radius: 0;
  background: linear-gradient(
    90deg,
    rgba(23, 26, 31, 0.06) 25%,
    rgba(23, 26, 31, 0.12) 37%,
    rgba(23, 26, 31, 0.06) 63%
  );
  background-size: 400% 100%;
  animation: state-shimmer 1.2s linear infinite;
}

.state-skeleton__content {
  flex: 1;
  padding: 18rpx 20rpx 18rpx 28rpx;
}

.state-skeleton__line {
  height: 22rpx;
  margin-bottom: 14rpx;
  border-radius: 10rpx;
  background: linear-gradient(
    90deg,
    rgba(23, 26, 31, 0.06) 25%,
    rgba(23, 26, 31, 0.12) 37%,
    rgba(23, 26, 31, 0.06) 63%
  );
  background-size: 400% 100%;
  animation: state-shimmer 1.2s linear infinite;
}

.state-skeleton__line--w90 { width: 90%; }
.state-skeleton__line--w75 { width: 75%; }
.state-skeleton__line--w55 { width: 55%; }
.state-skeleton__line--w45 { width: 45%; }

.state-skeleton__row {
  display: flex;
  margin-top: 8rpx;
}

.state-skeleton__chip {
  width: 86rpx;
  height: 34rpx;
  margin-right: 10rpx;
  border-radius: 8rpx;
  background: linear-gradient(
    90deg,
    rgba(23, 26, 31, 0.06) 25%,
    rgba(23, 26, 31, 0.12) 37%,
    rgba(23, 26, 31, 0.06) 63%
  );
  background-size: 400% 100%;
  animation: state-shimmer 1.2s linear infinite;
}

.ticket-card {
  display: flex;
  margin-bottom: 22rpx;
  border-radius: var(--radius-card);
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  background: var(--color-surface);
  box-shadow: var(--shadow-light, var(--shadow-card));
  overflow: hidden;
}

.ticket-card__poster {
  position: relative;
  width: 220rpx;
  height: 294rpx;
  flex-shrink: 0;
}

.ticket-card__poster image {
  width: 100%;
  height: 100%;
}

.ticket-card__poster-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-main, var(--color-text-strong));
  background: rgba(23, 26, 31, 0.08);
}

.ticket-card__poster-placeholder text {
  font-size: 66rpx;
  font-weight: 600;
}

.ticket-card__stage-badge {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  z-index: 2;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--color-surface);
  background: var(--color-text-disabled, var(--color-text-muted));
}

.ticket-card__stage-badge--first,
.ticket-card__stage-badge--second {
  background: var(--color-primary);
}

.ticket-card__stage-badge--third {
  background: var(--color-accent);
}

.ticket-card__stage-badge--listed {
  color: var(--color-warning);
  border: 1rpx solid var(--color-warning);
  background: rgba(255, 176, 32, 0.1);
}

.ticket-card__stage-badge--ended,
.ticket-card__stage-badge--rumor,
.ticket-card__stage-badge--unknown {
  color: var(--color-text-disabled, var(--color-text-muted));
  background: rgba(23, 26, 31, 0.12);
}

.ticket-card__info {
  position: relative;
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx 16rpx 28rpx;
  display: flex;
  flex-direction: column;
}

.ticket-card__info::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 18rpx;
  bottom: 18rpx;
  border-left: 1rpx dashed rgba(23, 26, 31, 0.14);
}

.ticket-card__title {
  font-size: 36rpx;
  line-height: 50rpx;
  font-weight: 600;
  color: var(--color-text-main, var(--color-text-strong));
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.ticket-card__artist-wrap {
  margin-bottom: 10rpx;
}

.ticket-card__artist {
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-sub, var(--color-text-body));
}

.ticket-card__meta {
  margin-bottom: 10rpx;
}

.ticket-card__meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.ticket-card__meta-row:last-child {
  margin-bottom: 0;
}

.ticket-card__meta-label {
  flex-shrink: 0;
  margin-right: 8rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: var(--color-text-disabled, var(--color-text-muted));
}

.ticket-card__meta-value {
  min-width: 0;
  font-size: 24rpx;
  line-height: 34rpx;
  color: var(--color-text-sub, var(--color-text-body));
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ticket-card__presale {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  margin-bottom: 12rpx;
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(255, 176, 32, 0.14);
}

.ticket-card__presale-label {
  margin-right: 8rpx;
  font-size: 20rpx;
  line-height: 30rpx;
  color: rgba(159, 107, 0, 0.9);
}

.ticket-card__presale-time {
  font-size: 22rpx;
  line-height: 30rpx;
  color: var(--color-warning);
  font-weight: 700;
}

.ticket-card__bottom {
  margin-top: auto;
  padding-top: 8rpx;
  border-top: 1rpx dashed rgba(23, 26, 31, 0.12);
}

.ticket-card__platforms {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  margin-bottom: 10rpx;
  min-height: 34rpx;
}

.ticket-card__platform-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
  height: 34rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
  padding: 0 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  color: var(--color-primary);
  background: rgba(255, 90, 54, 0.12);
}

.ticket-card__platform-empty {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  line-height: 30rpx;
  color: var(--color-text-disabled, var(--color-text-muted));
}

.ticket-card__cta-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.ticket-card__actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ticket-card__seatmap-btn {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  text-align: center;
  border-radius: var(--radius-btn);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  background: rgba(255, 90, 54, 0.12);
}

.ticket-card__price {
  display: flex;
  align-items: flex-end;
  color: var(--color-primary);
}

.ticket-card__price-symbol {
  font-size: 22rpx;
  line-height: 30rpx;
}

.ticket-card__price-value {
  font-size: 34rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.ticket-card__subscribe {
  min-width: 144rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  text-align: center;
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-surface);
  background: var(--color-primary);
}

.ticket-card__subscribe--on {
  background: var(--color-accent);
}

.state-empty,
.state-error {
  min-height: 380rpx;
  padding: 80rpx 32rpx 70rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-empty__icon-wrap,
.state-error__icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.state-empty__icon-wrap {
  background: rgba(255, 90, 54, 0.1);
}

.state-empty__icon {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.state-empty__title,
.state-error__title {
  font-size: 32rpx;
  line-height: 46rpx;
  font-weight: 600;
  color: var(--color-text-main, var(--color-text-strong));
}

.state-empty__desc,
.state-error__desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text-sub, var(--color-text-body));
}

.state-error__icon {
  background: rgba(255, 176, 32, 0.2);
  color: var(--color-warning);
  font-size: 56rpx;
  font-weight: 700;
}

.state-error__btn {
  margin-top: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-btn);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-surface);
  background: var(--color-primary);
}

.load-more {
  padding: 20rpx 0 46rpx;
  text-align: center;
}

.load-more text {
  font-size: 24rpx;
  color: var(--color-text-disabled, var(--color-text-muted));
}

@keyframes state-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
