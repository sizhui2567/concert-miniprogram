/* pages/index/index.wxss - 优化版本 */
/* 浮动卡片设计升级 - 更现代的视觉效果 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--c-fafafa) 0%, var(--c-f0f0f0) 100%);
}

/* ========== 搜索头部优化 ========== */
.search-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 50%, var(--c-ffb4b4) 100%);
  padding: 24rpx 30rpx 30rpx;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.25);
}

.search-box {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 28rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.search-box:focus-within {
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-2rpx);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--ng-text-primary);
}

.search-placeholder {
  color: var(--c-aaa);
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 50%;
  margin-left: 12rpx;
}

/* ========== 城市筛选优化 ========== */
.city-filter {
  display: flex;
  white-space: nowrap;
  padding: 24rpx 20rpx;
  background-color: var(--ng-bg-surface);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.city-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 32rpx;
  margin: 0 10rpx;
  font-size: 26rpx;
  color: var(--ng-text-secondary);
  background-color: var(--ng-bg-elevated);
  border-radius: 32rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.city-item:active {
  transform: scale(0.95);
}

.city-item.active {
  color: var(--ng-bg-surface);
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.35);
  border-color: rgba(255, 255, 255, 0.3);
}

/* ========== 搜索提示优化 ========== */
.search-tips {
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  color: var(--ng-text-secondary);
  background: linear-gradient(90deg, rgba(255, 107, 107, 0.1) 0%, transparent 100%);
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid var(--ng-accent);
}

/* ========== 演唱会列表 ========== */
.concert-list {
  padding: 20rpx;
}

/* ========== 浮动卡片优化 - 核心样式 ========== */
.concert-card-horizontal {
  display: flex;
  position: relative;
  background: linear-gradient(145deg, var(--c-ffffff) 0%, var(--c-fafafa) 100%);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  box-shadow: 
    0 8rpx 24rpx rgba(0, 0, 0, 0.06),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.concert-card-horizontal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--ng-accent) 0%, var(--ng-accent-strong) 50%, var(--c-ffb4b4) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.concert-card-horizontal:active {
  transform: translateY(4rpx) scale(0.99);
  box-shadow: 
    0 4rpx 12rpx rgba(0, 0, 0, 0.04),
    0 1rpx 4rpx rgba(0, 0, 0, 0.02);
}

.concert-card-horizontal:active::before {
  opacity: 1;
}

/* 左侧海报优化 */
.card-poster {
  position: relative;
  width: 220rpx;
  height: 280rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 20rpx 0 0 20rpx;
}

.card-poster::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.3) 100%);
  pointer-events: none;
}

.card-poster image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.concert-card-horizontal:active .card-poster image {
  transform: scale(1.05);
}

/* 海报占位符优化 */
.poster-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--c-f0f0f0) 0%, var(--c-e0e0e0) 50%, var(--ng-bg-elevated) 100%);
}

.poster-placeholder text {
  font-size: 80rpx;
  filter: grayscale(0.3);
}

/* 阶段标签优化 */
.stage-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 18rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--ng-bg-surface);
  border-radius: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  z-index: 10;
  backdrop-filter: blur(4px);
}

.stage-badge.stage-rumor { 
  background: linear-gradient(135deg, var(--c-95a5a6) 0%, var(--c-7f8c8d) 100%);
}
.stage-badge.stage-listed { 
  background: linear-gradient(135deg, var(--c-3498db) 0%, var(--c-2980b9) 100%);
}
.stage-badge.stage-first { 
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--c-e74c3c) 100%);
}
.stage-badge.stage-second { 
  background: linear-gradient(135deg, var(--c-9b59b6) 0%, var(--c-8e44ad) 100%);
}
.stage-badge.stage-third { 
  background: linear-gradient(135deg, var(--c-f39c12) 0%, var(--c-e67e22) 100%);
}
.stage-badge.stage-ended { 
  background: linear-gradient(135deg, var(--c-bdc3c7) 0%, var(--c-95a5a6) 100%);
}
.stage-badge.stage-unknown { 
  background: linear-gradient(135deg, var(--c-bdc3c7) 0%, var(--c-7f8c8d) 100%);
}

/* 右侧信息优化 */
.card-info {
  flex: 1;
  padding: 24rpx 24rpx 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-1a1a1a);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
  letter-spacing: 0.02em;
}

.card-artist {
  margin-bottom: 14rpx;
}

.artist-name {
  font-size: 26rpx;
  color: var(--ng-accent);
  font-weight: 600;
  background: linear-gradient(90deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 元信息优化 */
.card-meta {
  margin-bottom: 14rpx;
  padding: 10rpx 0;
  border-top: 1rpx dashed rgba(0, 0, 0, 0.06);
  border-bottom: 1rpx dashed rgba(0, 0, 0, 0.06);
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--ng-text-secondary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-icon {
  margin-right: 8rpx;
  font-size: 22rpx;
  filter: saturate(1.2);
}

/* 预售时间优化 */
.card-presale {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background: linear-gradient(90deg, var(--c-fff5f5) 0%, rgba(255, 107, 107, 0.05) 100%);
  border-radius: 10rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.1);
}

.presale-label {
  font-size: 20rpx;
  color: var(--c-888);
  margin-right: 8rpx;
}

.presale-time {
  font-size: 22rpx;
  color: var(--ng-accent);
  font-weight: 600;
}

/* 底部平台和价格优化 */
.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 10rpx;
}

.platform-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  max-width: 65%;
}

.platform-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: var(--ng-accent);
  background: linear-gradient(135deg, var(--c-fff5f5) 0%, var(--c-fff0f0) 100%);
  border: 1rpx solid rgba(255, 107, 107, 0.2);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 107, 0.1);
}

.platform-empty {
  font-size: 22rpx;
  color: var(--c-bbb);
}

.card-price {
  display: flex;
  align-items: baseline;
  background: linear-gradient(135deg, var(--c-fff5f5) 0%, var(--c-ffe8e8) 100%);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.15);
}

.price-symbol {
  font-size: 20rpx;
  color: var(--ng-accent);
  font-weight: 600;
}

.price-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ng-accent);
  margin-left: 2rpx;
}

/* 订阅按钮优化 */
.subscribe-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ng-bg-surface);
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  border-radius: 28rpx;
  z-index: 10;
  box-shadow: 
    0 6rpx 16rpx rgba(255, 107, 107, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.subscribe-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 10rpx rgba(255, 107, 107, 0.3);
}

.subscribe-btn.subscribed {
  background: linear-gradient(135deg, var(--c-e0e0e0) 0%, var(--c-d0d0d0) 100%);
  color: var(--c-888);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border-color: rgba(255, 255, 255, 0.5);
}

/* ========== 空状态优化 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
  filter: grayscale(0.5);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-state text {
  font-size: 28rpx;
  color: var(--ng-text-muted);
  letter-spacing: 0.05em;
}

/* ========== 加载更多优化 ========== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.load-more text {
  font-size: 26rpx;
  color: var(--c-aaa);
  padding: 16rpx 32rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 30rpx;
}

/* ========== 骨架屏样式 ========== */
.skeleton {
  padding: 20rpx;
}

.skeleton-card {
  display: flex;
  background: var(--ng-bg-surface);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.skeleton-poster {
  width: 220rpx;
  height: 280rpx;
  background: linear-gradient(90deg, var(--c-f0f0f0) 25%, var(--c-e0e0e0) 50%, var(--c-f0f0f0) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-content {
  flex: 1;
  padding: 24rpx;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, var(--c-f0f0f0) 25%, var(--c-e0e0e0) 50%, var(--c-f0f0f0) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-line.medium {
  width: 80%;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ========== 开发面板优化 ========== */
.dev-panel {
  margin: 20rpx;
  padding: 20rpx;
  background: linear-gradient(145deg, var(--c-ffffff) 0%, var(--c-fafafa) 100%);
  border-radius: 20rpx;
  border: 2rpx dashed var(--c-ffd6d6);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.dev-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.dev-title {
  font-size: 26rpx;
  color: var(--ng-accent);
  font-weight: 600;
}

.dev-btn {
  padding: 0 24rpx;
  font-size: 24rpx;
  line-height: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  color: var(--ng-bg-surface);
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.dev-btn[disabled] {
  background: var(--c-e0e0e0);
  color: var(--ng-text-muted);
  box-shadow: none;
}

.dev-result {
  background-color: var(--c-fff9f9);
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: var(--ng-text-secondary);
  white-space: pre-wrap;
  border: 1rpx solid rgba(255, 107, 107, 0.1);
}

/* Night Gold global override */
.container {
  background: linear-gradient(180deg, var(--c-0f1115) 0%, var(--c-151922) 52%, var(--c-10131a) 100%);
}

.search-header {
  background: linear-gradient(135deg, var(--c-151922) 0%, var(--c-1f2733) 100%);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

.search-box,
.city-filter,
.concert-card-horizontal,
.dev-panel {
  background: var(--c-151922);
  border: 1rpx solid rgba(201, 168, 106, 0.16);
}

.search-input,
.card-title,
.dev-title {
  color: var(--c-f5f2ea);
}

.search-placeholder,
.meta-item,
.search-tips,
.platform-empty,
.empty-state text,
.load-more text,
.dev-result {
  color: var(--c-b8b4aa);
}

.search-tips,
.card-presale,
.platform-tag,
.dev-result {
  background: rgba(201, 168, 106, 0.12);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
}

.artist-name,
.presale-time,
.price-symbol,
.price-value,
.platform-tag {
  color: var(--c-dfbf84);
}

.city-item,
.subscribe-btn.subscribed,
.dev-btn[disabled] {
  background: var(--c-1f2733);
  color: var(--c-b8b4aa);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
}

.city-item.active,
.subscribe-btn,
.dev-btn {
  background: linear-gradient(135deg, var(--c-c9a86a) 0%, var(--c-dfbf84) 100%);
  color: var(--c-10131a);
}
