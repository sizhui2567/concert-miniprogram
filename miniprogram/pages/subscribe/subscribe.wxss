/* pages/subscribe/subscribe.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 标签栏 */
.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 20rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #FF6B6B;
  font-weight: 500;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 3rpx;
}

/* 内容区域 */
.content-section {
  padding: 10rpx 0 20rpx;
}

/* 艺人列表 */
.artist-list {
  padding: 0 20rpx;
}

.artist-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.artist-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.artist-info {
  flex: 1;
}

.artist-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.artist-alias {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.artist-actions {
  display: flex;
  align-items: center;
}

.btn-unfollow {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #999;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.btn-explore {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 40rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 50rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #999;
}
