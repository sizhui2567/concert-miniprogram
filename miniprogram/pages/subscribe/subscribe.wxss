/* pages/subscribe/subscribe.wxss */
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.tabs {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(23, 26, 31, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 16rpx;
  font-size: 28rpx;
  color: var(--color-text-muted);
  position: relative;
}

.tab-item.active {
  color: var(--color-text-strong);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 56rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--color-primary);
}

.overview-strip {
  margin: 16rpx 24rpx 8rpx;
  padding: 18rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.overview-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-num {
  font-family: var(--ff-number);
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--color-primary);
}

.overview-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-body);
}

.content-section {
  padding: 8rpx 0 24rpx;
}

.notify-settings {
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
}

.notify-title {
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: var(--color-text-strong);
  margin-bottom: 12rpx;
}

.notify-item {
  padding: 12rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--color-text-body);
}

.notify-custom {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.notify-input {
  width: 100rpx;
  height: 56rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dbe1ea;
  background: #f8fafc;
  font-size: 24rpx;
  color: var(--color-text-strong);
}

.notify-unit {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.notify-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.concert-list {
  padding: 0 24rpx;
}

.timeline-list {
  position: relative;
}

.timeline-list::before {
  content: '';
  position: absolute;
  left: 56rpx;
  top: 8rpx;
  bottom: 12rpx;
  width: 2rpx;
  background: repeating-linear-gradient(
    to bottom,
    rgba(153, 162, 179, 0.68) 0,
    rgba(153, 162, 179, 0.68) 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
}

.timeline-row {
  position: relative;
  padding-left: 86rpx;
  margin-bottom: 14rpx;
}

.timeline-time {
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 54rpx;
  text-align: right;
  font-family: var(--ff-number);
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-warning);
}

.timeline-dot {
  position: absolute;
  left: 50rpx;
  top: 22rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-warning);
  box-shadow: 0 0 0 8rpx rgba(255, 176, 32, 0.18);
}

.concert-item {
  padding: 20rpx;
}

.concert-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.concert-title {
  flex: 1;
  font-size: 30rpx;
  line-height: 44rpx;
  color: var(--color-text-strong);
  font-weight: 600;
}

.concert-stage {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  color: var(--color-warning);
  border: 1rpx solid var(--color-warning);
  background: rgba(255, 176, 32, 0.1);
  font-size: 20rpx;
  white-space: nowrap;
}

.concert-row {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.concert-row-label {
  width: 116rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.concert-row-value {
  flex: 1;
  font-size: 23rpx;
  line-height: 1.5;
  color: var(--color-text-body);
}

.concert-row-value.highlight {
  font-family: var(--ff-number);
  color: var(--color-primary);
  font-weight: 700;
}

.concert-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.concert-action-btn {
  flex: 1;
  margin: 0;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: var(--radius-btn);
  font-size: 24rpx;
  border: none;
}

.concert-action-btn::after {
  border: none;
}

.concert-action-btn.ghost {
  color: var(--color-primary);
  background: #fff0ed;
  border: 1rpx solid rgba(255, 90, 54, 0.24);
}

.concert-action-btn.solid {
  color: #ffffff;
  background: var(--color-primary);
  font-weight: 600;
}

.concert-action-btn:active {
  transform: scale(0.98);
}

.artist-list {
  padding: 0 24rpx;
}

.artist-item {
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.artist-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  margin-right: 18rpx;
}

.artist-info {
  flex: 1;
  min-width: 0;
}

.artist-name {
  font-size: 30rpx;
  color: var(--color-text-strong);
  font-weight: 600;
}

.artist-alias {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.btn-unfollow {
  min-width: 124rpx;
  text-align: center;
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: var(--color-text-body);
  background: #f3f5f8;
  border: 1rpx solid #dde3eb;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-state image {
  width: 210rpx;
  height: 210rpx;
  margin-bottom: 24rpx;
  opacity: 0.72;
}

.empty-state text {
  font-size: 27rpx;
  color: var(--color-text-body);
}

.empty-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.btn-explore {
  margin-top: 30rpx;
  min-width: 220rpx;
  text-align: center;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 39rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: var(--color-primary);
  box-shadow: 0 10rpx 18rpx rgba(255, 90, 54, 0.22);
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0 46rpx;
}

.load-more text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
