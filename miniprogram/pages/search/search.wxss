/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding-right: 20rpx;
}

.search-bar-wrapper {
  flex: 1;
}

.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.filter-btn image {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.filter-btn text {
  font-size: 20rpx;
  color: #666;
}

/* 筛选面板 */
.filter-panel {
  max-height: 0;
  overflow: hidden;
  background-color: #fff;
  transition: max-height 0.3s ease;
}

.filter-panel.show {
  max-height: 600rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-section {
  padding: 20rpx 30rpx;
}

.filter-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.filter-option.active {
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
}

.filter-actions {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-reset {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  border: none;
}

/* 搜索历史 */
.search-history {
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.history-clear {
  font-size: 24rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

/* 热门搜索 */
.hot-search {
  padding: 30rpx;
  background-color: #fff;
}

.hot-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

/* 搜索结果 */
.search-results {
  padding-top: 10rpx;
}

.results-count {
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #999;
}

.concert-list {
  padding-bottom: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 50rpx;
}

.load-more text {
  font-size: 26rpx;
  color: #999;
}
