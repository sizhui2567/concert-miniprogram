/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--ng-bg-page) 0%, var(--ng-bg-surface) 52%, var(--c-10131a) 100%);
}

.search-header {
  display: flex;
  align-items: center;
  background: var(--ng-bg-surface);
  border-bottom: 1rpx solid var(--ng-border);
  padding-right: 20rpx;
}

.search-bar-wrapper {
  flex: 1;
}

.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.filter-btn image {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.filter-btn text {
  font-size: 20rpx;
  color: var(--ng-text-secondary);
}

.filter-panel {
  max-height: 0;
  overflow: hidden;
  background: var(--ng-bg-surface);
  transition: max-height 0.3s ease;
}

.filter-panel.show {
  max-height: 600rpx;
  border-bottom: 1rpx solid var(--ng-border);
}

.filter-section {
  padding: 20rpx 30rpx;
}

.filter-title {
  font-size: 26rpx;
  color: var(--ng-text-secondary);
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: var(--c-d7d0c3);
  background: var(--c-1f2733);
  border: 1rpx solid var(--ng-border);
  border-radius: 24rpx;
}

.filter-option.active {
  color: var(--c-10131a);
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
}

.filter-actions {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid var(--ng-border);
}

.btn-reset {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: var(--c-d7d0c3);
  background: var(--c-1f2733);
  border: 1rpx solid var(--ng-border);
  border-radius: 36rpx;
  margin: 0;
}

.btn-reset::after {
  border: none;
}

.search-history,
.hot-search {
  padding: 30rpx;
  background: var(--ng-bg-surface);
  margin-bottom: 20rpx;
  border-top: 1rpx solid var(--ng-border);
  border-bottom: 1rpx solid var(--ng-border);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title,
.hot-title {
  font-size: 28rpx;
  color: var(--ng-text-primary);
  font-weight: 500;
  margin-bottom: 20rpx;
}

.history-clear {
  font-size: 24rpx;
  color: var(--ng-text-secondary);
}

.history-list,
.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item,
.hot-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: var(--c-d7d0c3);
  background: var(--c-1f2733);
  border: 1rpx solid var(--ng-border);
  border-radius: 24rpx;
}

.search-results {
  padding-top: 10rpx;
}

.results-count {
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: var(--ng-text-secondary);
}

.concert-list {
  padding-bottom: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--ng-text-secondary);
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--ng-text-muted);
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 50rpx;
}

.load-more text {
  font-size: 26rpx;
  color: var(--ng-text-secondary);
}
