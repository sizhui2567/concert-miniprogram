/* pages/tomorrow/tomorrow.wxss */
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.date-header {
  margin: 20rpx 24rpx 12rpx;
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: var(--radius-card);
  background:
    radial-gradient(circle at 6% 0%, rgba(255, 176, 32, 0.24) 0, rgba(255, 176, 32, 0) 42%),
    linear-gradient(140deg, #1a1a1a 0%, #2b2b2b 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.14);
}

.date-icon {
  font-size: 44rpx;
  margin-right: 18rpx;
}

.date-info {
  flex: 1;
}

.date-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.date-value {
  margin-top: 6rpx;
  display: block;
  font-family: var(--ff-number);
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.concert-count {
  min-width: 94rpx;
  text-align: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
}

.concert-list {
  padding: 6rpx 24rpx 30rpx;
}

.timeline-list {
  position: relative;
  margin-top: 8rpx;
}

.timeline-list::before {
  content: '';
  position: absolute;
  left: 68rpx;
  top: 10rpx;
  bottom: 10rpx;
  width: 2rpx;
  background: repeating-linear-gradient(
    to bottom,
    rgba(153, 162, 179, 0.7) 0,
    rgba(153, 162, 179, 0.7) 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
}

.timeline-group {
  position: relative;
  padding-left: 96rpx;
  margin-bottom: 16rpx;
}

.timeline-time {
  position: absolute;
  left: 0;
  top: 10rpx;
  min-width: 62rpx;
  text-align: right;
  font-family: var(--ff-number);
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-warning);
}

.timeline-group-body {
  position: relative;
}

.timeline-group-body::before {
  content: '';
  position: absolute;
  left: -34rpx;
  top: 30rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-warning);
  box-shadow: 0 0 0 8rpx rgba(255, 176, 32, 0.2);
}

.concert-item {
  margin-bottom: 14rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  box-shadow: var(--shadow-card);
}

.countdown-section {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70rpx;
  padding: 14rpx 16rpx;
  background: rgba(255, 176, 32, 0.14);
  border-bottom: 1rpx dashed rgba(255, 176, 32, 0.4);
}

.countdown-section.expired {
  background: #eef2f6;
  border-bottom-color: #d7dde6;
}

.countdown-label {
  margin-right: 16rpx;
  font-size: 22rpx;
  color: #9f6b00;
}

.countdown-timer {
  display: flex;
  align-items: center;
}

.countdown-block {
  display: flex;
  align-items: baseline;
  margin: 0 6rpx;
}

.countdown-num {
  min-width: 40rpx;
  text-align: center;
  font-family: var(--ff-number);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  color: var(--color-warning);
}

.countdown-unit {
  margin-left: 2rpx;
  font-size: 20rpx;
  color: #9f6b00;
}

.expired-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.concert-content {
  display: flex;
  padding: 18rpx;
}

.concert-poster {
  width: 176rpx;
  height: 176rpx;
  border-radius: 12rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.concert-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.concert-title {
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: var(--color-text-strong);
  margin-bottom: 10rpx;
}

.concert-meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--color-text-body);
  margin-bottom: 8rpx;
}

.meta-icon {
  margin-right: 8rpx;
  font-size: 20rpx;
}

.price {
  color: var(--color-primary);
  font-family: var(--ff-number);
  font-weight: 700;
}

.platforms {
  margin-top: auto;
  padding-top: 8rpx;
}

.concert-actions {
  padding: 0 18rpx 18rpx;
}

.btn-remind {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  margin: 0;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--color-primary);
}

.btn-remind.reminded {
  background: var(--color-accent);
}

.btn-remind::after {
  border: none;
}

.btn-remind:active {
  transform: scale(0.98);
}

.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-state image {
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}

.empty-state text,
.loading-state text {
  font-size: 27rpx;
  color: var(--color-text-body);
}

.empty-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.loading-spinner {
  width: 58rpx;
  height: 58rpx;
  border: 4rpx solid #e6eaf0;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 18rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
