/* pages/tomorrow/tomorrow.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 日期头部 */
.date-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.date-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.date-info {
  flex: 1;
}

.date-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.date-value {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-top: 4rpx;
}

.concert-count {
  padding: 10rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 演唱会列表 */
.concert-list {
  padding: 20rpx;
}

.concert-item {
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 倒计时区域 */
.countdown-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.countdown-section.expired {
  background: #999;
}

.countdown-label {
  font-size: 24rpx;
  margin-right: 20rpx;
}

.countdown-timer {
  display: flex;
  align-items: center;
}

.countdown-block {
  display: flex;
  align-items: baseline;
  margin: 0 8rpx;
}

.countdown-num {
  font-size: 40rpx;
  font-weight: 600;
  min-width: 48rpx;
  text-align: center;
}

.countdown-unit {
  font-size: 20rpx;
  opacity: 0.8;
  margin-left: 4rpx;
}

.expired-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 演唱会内容 */
.concert-content {
  display: flex;
  padding: 24rpx;
}

.concert-poster {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.concert-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.concert-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.concert-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.meta-icon {
  margin-right: 8rpx;
  font-size: 22rpx;
}

.price {
  color: #FF6B6B;
  font-weight: 500;
}

.platforms {
  margin-top: auto;
  padding-top: 12rpx;
}

/* 操作按钮 */
.concert-actions {
  padding: 0 24rpx 24rpx;
}

.btn-remind {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 40rpx;
  border: none;
}

.btn-remind.reminded {
  background: #f5f5f5;
  color: #999;
}

.btn-remind::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-state text {
  font-size: 28rpx;
  color: #999;
}
