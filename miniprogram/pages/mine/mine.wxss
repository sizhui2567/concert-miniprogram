/* pages/mine/mine.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--c-0f1115) 0%, var(--c-151922) 52%, var(--c-10131a) 100%);
}

/* 用户信息区域 */
.user-section {
  background: linear-gradient(145deg, var(--c-141923) 0%, var(--c-1b2230) 100%);
  border-bottom: 1rpx solid rgba(201, 168, 106, 0.2);
  padding: 60rpx 30rpx 40rpx;
  margin-bottom: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 140rpx;
  height: 140rpx;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(201, 168, 106, 0.35);
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-f5f2ea);
  background: transparent;
}

.nickname-input::placeholder {
  color: rgba(184, 180, 170, 0.7);
}

/* 统计数据 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 168, 106, 0.12);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
  border-radius: 16rpx;
  padding: 30rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--c-dfbf84);
}

.stat-label {
  font-size: 24rpx;
  color: var(--c-b8b4aa);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(201, 168, 106, 0.24);
}

.profile-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--c-a9a396);
}

/* 功能菜单 */
.menu-section {
  padding: 0 20rpx;
}

.menu-group {
  background: var(--c-151922);
  border: 1rpx solid rgba(201, 168, 106, 0.16);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid rgba(201, 168, 106, 0.1);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-btn {
  background: transparent;
  text-align: left;
  font-size: inherit;
  font-weight: normal;
  line-height: inherit;
  margin: 0;
}

.menu-btn::after {
  border: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--c-f5f2ea);
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.admin-item {
  background: rgba(201, 168, 106, 0.12);
}

.admin-item .menu-text {
  color: var(--c-dfbf84);
}

/* 隐藏的管理入口 */
.hidden-admin {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.version {
  font-size: 24rpx;
  color: var(--c-7f7a70);
}

/* 分享按钮 */
.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 20rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, var(--c-c9a86a) 0%, var(--c-dfbf84) 100%);
  border-radius: 44rpx;
  border: none;
}

.share-btn::after {
  border: none;
}

.share-btn image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.share-btn text {
  font-size: 30rpx;
  color: var(--c-10131a);
  font-weight: 600;
}
