<!-- pages/mine/mine.wxml -->
<view class="container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-card">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          class="avatar"
          src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
          mode="aspectFill"
        />
      </button>
      <view class="user-info">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="点击设置昵称"
          value="{{userInfo.nickname || ''}}"
          bindblur="onInputNickname"
        />
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-row">
      <view class="stat-item" bindtap="onGoSubscribe">
        <text class="stat-num">{{subscribeCount}}</text>
        <text class="stat-label">订阅演唱会</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item" bindtap="onGoSubscribe">
        <text class="stat-num">{{followCount}}</text>
        <text class="stat-label">关注艺人</text>
      </view>
    </view>

    <view class="profile-tip">你的订阅提醒会优先出现在开售前窗口，建议保持通知开启。</view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="onGoSubscribe">
        <image class="menu-icon" src="/images/icon-subscribe.png" mode="aspectFit" />
        <text class="menu-text">我的订阅</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="onClearCache">
        <image class="menu-icon" src="/images/icon-cache.png" mode="aspectFit" />
        <text class="menu-text">清除缓存</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="onAbout">
        <image class="menu-icon" src="/images/icon-about.png" mode="aspectFit" />
        <text class="menu-text">关于我们</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </view>
      <button class="menu-item menu-btn" open-type="feedback">
        <image class="menu-icon" src="/images/icon-feedback.png" mode="aspectFit" />
        <text class="menu-text">意见反馈</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </button>
      <button class="menu-item menu-btn" open-type="contact">
        <image class="menu-icon" src="/images/icon-contact.png" mode="aspectFit" />
        <text class="menu-text">联系客服</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </button>
    </view>

    <!-- 管理入口（仅管理员可见） -->
    <view class="menu-group" wx:if="{{isAdmin}}">
      <view class="menu-item admin-item" bindtap="onGoAdmin">
        <image class="menu-icon" src="/images/icon-admin.png" mode="aspectFit" />
        <text class="menu-text">管理后台</text>
        <image class="menu-arrow" src="/images/icon-arrow.png" mode="aspectFit" />
      </view>
    </view>

    <!-- 隐藏的管理入口（长按触发） -->
    <view class="hidden-admin" bindlongpress="onGoAdmin">
      <text class="version">v1.0.0</text>
    </view>
  </view>

  <!-- 分享按钮 -->
  <button class="share-btn" open-type="share">
    <image src="/images/icon-share.png" mode="aspectFit" />
    <text>分享给朋友</text>
  </button>
</view>
