/* pages/admin/artists/artists.wxss */
.container {
  min-height: 100vh;
  background-color: var(--ng-bg-elevated);
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 艺人列表 */
.artist-list {
  /* padding: 20rpx; */
}

.artist-item {
  background-color: var(--ng-bg-surface);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.artist-content {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.artist-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.artist-info {
  flex: 1;
}

.artist-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ng-text-primary);
  margin-bottom: 6rpx;
}

.artist-alias {
  font-size: 24rpx;
  color: var(--ng-text-muted);
  margin-bottom: 6rpx;
}

.artist-stats {
  font-size: 22rpx;
  color: var(--c-ccc);
}

.artist-actions {
  display: flex;
  border-top: 1rpx solid var(--ng-bg-elevated);
}

.action-edit,
.action-delete {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.action-edit {
  color: var(--ng-accent);
  border-right: 1rpx solid var(--ng-bg-elevated);
}

.action-delete {
  color: var(--c-e74c3c);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: var(--ng-text-muted);
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--c-ccc);
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.add-btn text {
  font-size: 56rpx;
  color: var(--ng-bg-surface);
  line-height: 1;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background-color: var(--ng-bg-surface);
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--ng-bg-elevated);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ng-text-primary);
}

.modal-close {
  font-size: 48rpx;
  color: var(--ng-text-muted);
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: var(--ng-accent);
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--ng-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--ng-text-primary);
  background-color: var(--ng-bg-elevated);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-hint {
  font-size: 22rpx;
  color: var(--ng-text-muted);
  margin-top: 8rpx;
  display: block;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  margin: 0;
}

.btn-cancel {
  background: var(--ng-bg-elevated);
  color: var(--ng-text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  color: var(--ng-bg-surface);
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

/* Night Gold override */
.container {
  background: linear-gradient(180deg, var(--c-0f1115) 0%, var(--c-151922) 52%, var(--c-10131a) 100%);
}

.artist-item,
.modal-content {
  background: var(--c-151922);
  border: 1rpx solid rgba(201, 168, 106, 0.16);
}

.artist-name,
.modal-title,
.form-input {
  color: var(--c-f5f2ea);
}

.artist-alias,
.artist-stats,
.empty-state text,
.form-label,
.form-hint,
.modal-close {
  color: var(--c-b8b4aa);
}

.action-edit,
.avatar-tip {
  color: var(--c-dfbf84);
}

.artist-actions,
.modal-header,
.action-edit {
  border-color: rgba(201, 168, 106, 0.15);
}

.add-btn,
.btn-confirm {
  background: linear-gradient(135deg, var(--c-c9a86a) 0%, var(--c-dfbf84) 100%);
}

.add-btn text,
.btn-confirm {
  color: var(--c-10131a);
}

.btn-cancel,
.form-input {
  background: var(--c-1f2733);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
  color: var(--c-d7d0c3);
}

