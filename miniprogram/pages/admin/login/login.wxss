/* pages/admin/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-card {
  width: 100%;
  background-color: var(--ng-bg-surface);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--ng-text-primary);
}

.subtitle {
  font-size: 26rpx;
  color: var(--ng-text-muted);
  margin-top: 8rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background-color: var(--ng-bg-elevated);
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 30rpx;
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.5;
}

.input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--ng-text-primary);
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--ng-bg-surface);
  background: linear-gradient(135deg, var(--ng-accent) 0%, var(--ng-accent-strong) 100%);
  border-radius: 48rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.tips {
  text-align: center;
}

.tips text {
  font-size: 24rpx;
  color: var(--ng-text-muted);
}

/* Night Gold override */
.container {
  background: linear-gradient(145deg, var(--c-0f1115) 0%, var(--c-1a202c) 100%);
}

.login-card {
  background: var(--c-151922);
  border: 1rpx solid rgba(201, 168, 106, 0.18);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.38);
}

.title,
.input {
  color: var(--c-f5f2ea);
}

.subtitle,
.tips text {
  color: var(--c-b8b4aa);
}

.input-group {
  background: var(--c-1f2733);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
}

.btn-login {
  background: linear-gradient(135deg, var(--c-c9a86a) 0%, var(--c-dfbf84) 100%);
  color: var(--c-10131a);
}

