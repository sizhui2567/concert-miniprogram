/* pages/admin/list/list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding-right: 20rpx;
}

.search-wrapper {
  flex: 1;
}

.toolbar-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
}

.action-btn image {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 4rpx;
}

.action-btn text {
  font-size: 20rpx;
  color: #666;
}

.action-btn.logout text {
  color: #e74c3c;
}

/* 阶段筛选 */
.stage-filter {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 10rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.stage-item {
  display: inline-flex;
  padding: 12rpx 24rpx;
  margin: 0 10rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.stage-item.active {
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 演唱会列表 */
.concert-list {
  padding: 20rpx;
}

.concert-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.concert-content {
  display: flex;
  padding: 20rpx;
}

.concert-poster {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.concert-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.concert-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.concert-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.concert-meta .dot {
  margin: 0 8rpx;
}

.concert-bottom {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.update-time {
  font-size: 22rpx;
  color: #ccc;
  margin-left: auto;
}

.concert-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.status-draft,
.status-unverified {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 8rpx;
}

.status-draft {
  color: #e67e22;
  background-color: rgba(230, 126, 34, 0.1);
}

.status-unverified {
  color: #3498db;
  background-color: rgba(52, 152, 219, 0.1);
}

.concert-actions {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.action-edit,
.action-delete {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.action-edit {
  color: #667eea;
  border-right: 1rpx solid #f5f5f5;
}

.action-delete {
  color: #e74c3c;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more text {
  font-size: 26rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}
