<!-- pages/admin/edit/edit.wxml -->
<view class="container">
  <view class="form">
    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="form-label required">演唱会名称</text>
        <input
          class="form-input"
          placeholder="请输入演唱会名称"
          value="{{formData.title}}"
          bindinput="onInputTitle"
        />
      </view>

      <view class="form-item">
        <text class="form-label required">艺人</text>
        <picker mode="selector" range="{{artists}}" range-key="name" bindchange="onSelectArtist">
          <view class="form-picker">
            <text wx:if="{{formData.artist}}">{{formData.artist}}</text>
            <text wx:else class="placeholder">请选择艺人</text>
            <image class="picker-arrow" src="/images/icon-arrow-down.png" mode="aspectFit" />
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">城市</text>
        <picker mode="selector" range="{{cities}}" bindchange="onSelectCity">
          <view class="form-picker">
            <text wx:if="{{formData.city}}">{{formData.city}}</text>
            <text wx:else class="placeholder">请选择城市</text>
            <image class="picker-arrow" src="/images/icon-arrow-down.png" mode="aspectFit" />
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label required">场馆</text>
        <input
          class="form-input"
          placeholder="请输入场馆名称"
          value="{{formData.venue}}"
          bindinput="onInputVenue"
        />
      </view>

      <view class="form-item">
        <text class="form-label required">演出日期</text>
        <view class="dates-wrapper">
          <view class="date-tags">
            <view
              wx:for="{{selectedDates}}"
              wx:key="*this"
              class="date-tag"
            >
              <text>{{item}}</text>
              <text class="date-remove" data-date="{{item}}" bindtap="onRemoveDate">×</text>
            </view>
          </view>
          <picker mode="date" bindchange="onSelectDate">
            <view class="add-date-btn">+ 添加日期</view>
          </picker>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">价格区间</text>
        <input
          class="form-input"
          placeholder="如：380-1880"
          value="{{formData.priceRange}}"
          bindinput="onInputPrice"
        />
      </view>
    </view>

    <!-- 阶段状态 -->
    <view class="form-section">
      <view class="section-title">阶段状态</view>

      <view class="form-item">
        <text class="form-label required">当前阶段</text>
        <picker mode="selector" range="{{stages}}" bindchange="onSelectStage">
          <view class="form-picker">
            <text>{{formData.stage}}</text>
            <image class="picker-arrow" src="/images/icon-arrow-down.png" mode="aspectFit" />
          </view>
        </picker>
      </view>
    </view>

    <!-- 购票平台 -->
    <view class="form-section">
      <view class="section-title">购票平台</view>

      <view
        wx:for="{{platformList}}"
        wx:key="*this"
        class="platform-form-item"
      >
        <view class="platform-header">
          <view
            class="platform-checkbox {{formData.platforms[item].available ? 'checked' : ''}}"
            data-platform="{{item}}"
            bindtap="onTogglePlatform"
          >
            <view class="checkbox-inner"></view>
          </view>
          <text class="platform-name">{{item === 'damai' ? '大麦' : item === 'maoyan' ? '猫眼' : item === 'douyin' ? '抖音' : item === 'xiecheng' ? '携程' : '票星球'}}</text>
        </view>

        <view class="platform-fields" wx:if="{{formData.platforms[item].available}}">
          <input
            class="platform-input"
            placeholder="购票链接"
            value="{{formData.platforms[item].url}}"
            data-platform="{{item}}"
            bindinput="onInputPlatformUrl"
          />
          <input
            class="platform-input"
            placeholder="开售时间 (如: 2026-01-20 10:00)"
            value="{{formData.platforms[item].openTime}}"
            data-platform="{{item}}"
            bindinput="onInputPlatformTime"
          />
        </view>
      </view>
    </view>

    <!-- 海报图片 -->
    <view class="form-section">
      <view class="section-title">海报图片</view>

      <view class="poster-wrapper">
        <view wx:if="{{formData.poster}}" class="poster-preview">
          <image class="poster-image" src="{{formData.poster}}" mode="aspectFill" />
          <view class="poster-remove" bindtap="onRemovePoster">×</view>
        </view>
        <view wx:else class="poster-upload" bindtap="onChoosePoster">
          <image class="upload-icon" src="/images/icon-upload.png" mode="aspectFit" />
          <text>上传海报</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="action-bar safe-area-bottom">
    <button class="btn-draft" bindtap="onSaveDraft">保存草稿</button>
    <button class="btn-publish" bindtap="onPublish">发布</button>
  </view>
</view>
