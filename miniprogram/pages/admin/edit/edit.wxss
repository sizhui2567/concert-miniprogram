/* pages/admin/edit/edit.wxss */
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 168rpx;
}

.form {
  padding: 20rpx 24rpx;
}

.form-section {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: var(--radius-card);
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--fz-h2);
  line-height: var(--lh-h2);
  font-weight: 600;
  color: var(--color-text-strong);
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #dce2ea;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 25rpx;
  color: var(--color-text-body);
  margin-bottom: 10rpx;
}

.form-label.required::before {
  content: '*';
  color: #d9485f;
  margin-right: 4rpx;
}

.form-input,
.platform-input,
.generator-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  background: #f7f8fa;
  font-size: 27rpx;
  color: var(--color-text-strong);
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  background: #f7f8fa;
}

.form-picker.compact {
  min-height: 68rpx;
}

.form-picker text {
  flex: 1;
  font-size: 27rpx;
  color: var(--color-text-strong);
}

.form-picker .placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
}

.form-input:focus,
.platform-input:focus,
.generator-input:focus,
.form-picker:active {
  border-color: rgba(255, 90, 54, 0.5);
  box-shadow: 0 0 0 4rpx rgba(255, 90, 54, 0.12);
}

.dates-wrapper {
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.date-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.date-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 176, 32, 0.4);
  background: rgba(255, 176, 32, 0.12);
  font-size: 22rpx;
  color: #9f6b00;
}

.date-remove {
  font-size: 20rpx;
  color: #c66d00;
}

.add-date-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 176rpx;
  height: 58rpx;
  border-radius: 29rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: var(--color-primary);
}

.platform-form-item {
  margin-bottom: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f7f8fa;
}

.platform-form-item:last-child {
  margin-bottom: 0;
}

.platform-header {
  display: flex;
  align-items: center;
}

.platform-checkbox {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
  border: 2rpx solid #cfd6e1;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.platform-checkbox.checked {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.platform-checkbox.checked .checkbox-inner {
  width: 16rpx;
  height: 8rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
  margin-bottom: 4rpx;
}

.platform-name {
  font-size: 27rpx;
  color: var(--color-text-strong);
  font-weight: 600;
}

.platform-fields {
  margin-top: 12rpx;
}

.platform-input {
  margin-bottom: 10rpx;
}

.platform-input:last-child {
  margin-bottom: 0;
}

.poster-wrapper {
  display: flex;
}

.poster-preview {
  position: relative;
  width: 240rpx;
  height: 320rpx;
}

.poster-image {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
}

.poster-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 50%;
  color: #ffffff;
  background: #d9485f;
}

.poster-upload,
.seat-source-upload {
  width: 240rpx;
  height: 320rpx;
  border-radius: 14rpx;
  border: 2rpx dashed #ced6e2;
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  font-size: 24rpx;
}

.upload-plus {
  font-size: 50rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.seat-source-wrap {
  display: flex;
  margin-bottom: 14rpx;
}

.seat-source-preview {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f7f8fa;
}

.seat-source-image {
  width: 100%;
  height: 100%;
}

.seat-source-meta {
  position: absolute;
  left: 12rpx;
  bottom: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(23, 26, 31, 0.65);
}

.seat-source-meta text {
  font-size: 20rpx;
  color: #ffffff;
}

.preset-desc {
  margin-top: 8rpx;
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.seat-action-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.seat-btn {
  flex: 1;
  margin: 0;
  height: 74rpx;
  line-height: 74rpx;
  border: none;
  border-radius: var(--radius-btn);
  font-size: 24rpx;
  font-weight: 600;
}

.seat-btn::after {
  border: none;
}

.seat-btn.primary {
  color: #ffffff;
  background: var(--color-primary);
  box-shadow: 0 8rpx 18rpx rgba(255, 90, 54, 0.24);
}

.seat-btn.secondary {
  color: var(--color-primary);
  background: #fff0ed;
  border: 1rpx solid rgba(255, 90, 54, 0.22);
}

.generator-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.generator-item {
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.generator-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.generator-input {
  height: 66rpx;
}

.quality-panel,
.micro-adjust-panel,
.area-editor {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e6ebf3;
  background: #f9fafc;
}

.quality-head,
.seat-preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quality-title,
.micro-title,
.seat-preview-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-strong);
}

.quality-status {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #9f6b00;
  background: rgba(255, 176, 32, 0.14);
}

.quality-status.ok {
  color: #0f8e79;
  background: rgba(0, 194, 168, 0.14);
}

.quality-status.bad {
  color: #c23f55;
  background: rgba(217, 72, 95, 0.12);
}

.quality-fallback,
.quality-item,
.micro-label {
  font-size: 22rpx;
  color: var(--color-text-body);
}

.quality-list {
  margin-top: 8rpx;
}

.quality-item {
  line-height: 1.45;
  margin-top: 4rpx;
}

.quality-item.bad {
  color: #c23f55;
}

.seat-preview-block {
  margin-top: 16rpx;
}

.seat-preview-clear {
  font-size: 22rpx;
  color: var(--color-primary);
}

.seat-preview-selected {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 194, 168, 0.3);
  background: rgba(0, 194, 168, 0.1);
}

.seat-selected-name {
  font-size: 24rpx;
  color: var(--color-text-strong);
}

.seat-selected-price {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 700;
}

.micro-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.micro-label {
  width: 130rpx;
}

.micro-btn {
  margin: 0;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 14rpx;
  border-radius: 26rpx;
  font-size: 22rpx;
  border: 1rpx solid #d9e0ea;
  background: #ffffff;
  color: var(--color-text-body);
}

.micro-btn::after {
  border: none;
}

.area-actions {
  margin-top: 12rpx;
  margin-bottom: 0;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(23, 26, 31, 0.08);
  box-shadow: var(--shadow-sticky);
}

.btn-draft,
.btn-publish {
  flex: 1;
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
}

.btn-draft::after,
.btn-publish::after {
  border: none;
}

.btn-draft {
  color: var(--color-primary);
  background: #fff0ed;
  border: 1rpx solid rgba(255, 90, 54, 0.22);
}

.btn-publish {
  color: #ffffff;
  background: var(--color-primary);
}

.seat-btn:active,
.micro-btn:active,
.btn-draft:active,
.btn-publish:active,
.add-date-btn:active {
  transform: scale(0.98);
}
