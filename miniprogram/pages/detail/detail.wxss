}

.seat-map-inner,
.buddy-inner,
.announcement-inner {
  padding: 0 16rpx 20rpx;
}

.seat-locate-panel,
.seat-share-panel,
.buddy-form-panel,
.announcement-form-panel {
  background: #f9fafc;
  border: 1rpx solid #e8ecf2;
  border-radius: 20rpx;
}

.seat-locate-title,
.seat-share-title,
.buddy-form-title,
.announcement-form-title,
.seat-view-list-title,
.buddy-list-title,
.announcement-list-title {
  color: var(--color-text-strong);
}

.seat-locate-input,
.seat-share-note,
.seat-share-rating-picker,
.buddy-content-input,
.buddy-contact-input,
.buddy-form-picker,
.announcement-picker,
.announcement-content-input {
  background: #ffffff;
  border: 1rpx solid #dfe4ec;
  color: var(--color-text-strong);
  border-radius: 12rpx;
}

.seat-locate-btn,
.seat-share-btn,
.buddy-submit-btn,
.announcement-submit-btn,
.btn-subscribe {
  background: var(--color-primary);
