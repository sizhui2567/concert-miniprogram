}

.content-op-btn.report {
  background: rgba(255, 176, 32, 0.12);
  border-color: rgba(255, 176, 32, 0.35);
  color: #a86a00;
}

.content-op-btn.block,
.admin-op-btn.danger {
  background: rgba(217, 72, 95, 0.1);
  border-color: rgba(217, 72, 95, 0.35);
  color: #b23a4f;
}

.admin-op-btn {
  background: rgba(255, 90, 54, 0.1);
  border-color: rgba(255, 90, 54, 0.25);
  color: var(--color-primary);
}

.timeline::before {
  background: repeating-linear-gradient(
    to bottom,
    rgba(153, 162, 179, 0.55) 0,
    rgba(153, 162, 179, 0.55) 8rpx,
    transparent 8rpx,
    transparent 16rpx
  );
}

.timeline-stage {
  color: var(--color-text-strong);
}

.action-bar {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(10rpx);
  box-shadow: var(--shadow-sticky);
  border-top: 1rpx solid rgba(23, 26, 31, 0.08);
}

.btn-subscribe,
.btn-share {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
}

.btn-subscribe {
  background: var(--color-primary);
  color: #ffffff;
}

.btn-subscribe.subscribed {
  background: var(--color-accent);
  color: #ffffff;
  border: none;
}

.btn-share {
  background: #ffffff;
  color: var(--color-primary);
  border: 1rpx solid rgba(255, 90, 54, 0.25);
}

.btn-subscribe:active,
.btn-share:active,
.hero-subscribe-btn:active,
.platform-action:active,
.seat-locate-btn:active,
.seat-share-btn:active,
.buddy-submit-btn:active,
.announcement-submit-btn:active,
.buddy-copy-btn:active {
  transform: scale(0.98);
}