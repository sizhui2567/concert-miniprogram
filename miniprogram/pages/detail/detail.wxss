/* pages/detail/detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 海报区域 */
.poster-section {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.poster {
  width: 100%;
  height: 100%;
}

.poster-overlay {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

/* 基本信息 */
.info-section {
  margin: -60rpx 20rpx 20rpx;
  padding: 30rpx;
  position: relative;
  z-index: 10;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.artist {
  margin-bottom: 16rpx;
}

.artist .label {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.artist .value {
  font-size: 28rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row .icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.info-row .text {
  font-size: 28rpx;
  color: #666;
}

.info-row .price {
  color: #FF6B6B;
  font-weight: 600;
}

.dates-detail {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.dates-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.dates-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.date-item {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 6rpx;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 30rpx 16rpx;
}

/* 购票平台 */
.platforms-section {
  padding-bottom: 10rpx;
}

.platform-list {
  padding: 0 20rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  padding: 24rpx 10rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.platform-item:last-child {
  border-bottom: none;
}

.platform-item.unavailable {
  opacity: 0.5;
}

.platform-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.platform-info {
  flex: 1;
}

.platform-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.platform-status {
  font-size: 22rpx;
  color: #4CD964;
  display: block;
  margin-top: 6rpx;
}

.platform-status.unavailable {
  color: #999;
}

.platform-action {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 24rpx;
}

.action-text {
  font-size: 24rpx;
  color: #fff;
}

/* 阶段时间线 */
.timeline-section {
  padding-bottom: 20rpx;
}

.timeline {
  padding: 0 30rpx 0 50rpx;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 38rpx;
  top: 10rpx;
  bottom: 10rpx;
  width: 2rpx;
  background-color: #e0e0e0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  position: relative;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  position: absolute;
  left: -19rpx;
  top: 22rpx;
}

.timeline-content {
  flex: 1;
  padding-left: 10rpx;
}

.timeline-stage {
  font-size: 28rpx;
  font-weight: 500;
}

.timeline-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 相关演唱会 */
.related-section {
  padding: 0 0 20rpx;
}

.related-section .section-title {
  padding-left: 30rpx;
}

.related-list {
  display: flex;
  white-space: nowrap;
  padding: 0 20rpx;
}

.related-item {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.related-poster {
  width: 100%;
  height: 160rpx;
  border-radius: 12rpx 12rpx 0 0;
}

.related-info {
  padding: 16rpx;
}

.related-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.related-city {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.btn-subscribe,
.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  margin: 0;
}

.btn-subscribe {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.btn-subscribe.subscribed {
  background: #f5f5f5;
  color: #999;
}

.btn-share {
  background: #f5f5f5;
  color: #666;
}

.btn-subscribe::after,
.btn-share::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-state text {
  font-size: 28rpx;
  color: #999;
}
