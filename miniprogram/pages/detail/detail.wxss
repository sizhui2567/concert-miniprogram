}

.platform-name {
  color: var(--color-text-strong);
}

.platform-status {
  color: var(--color-accent);
}

.platform-action {
  border-radius: var(--radius-btn);
  background: #fff0ed;
  border: 1rpx solid rgba(255, 90, 54, 0.2);
}

.action-text {
  color: var(--color-primary);
}

.seat-map-section,
.buddy-section,
.announcement-section,
.timeline-section {
  margin-left: 24rpx;
