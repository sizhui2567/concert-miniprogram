  background: rgba(255, 176, 32, 0.15);
}

.announcement-time,
.buddy-time,
.seat-view-time,
.buddy-count,
.official-switch-label,
.buddy-content,
.announcement-content,
.seat-view-note,
.buddy-contact,
.buddy-form-label,
.seat-view-status,
.announcement-picker,
.announcement-toolbar {
