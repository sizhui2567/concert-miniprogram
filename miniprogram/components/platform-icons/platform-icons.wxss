/* components/platform-icons/platform-icons.wxss */
.platform-icons {
  display: flex;
  justify-content: space-around;
  align-items: center;
  gap: 10rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateZ(0);
}

.platform-item.inactive {
  opacity: 0.48;
  filter: grayscale(80%);
}

.platform-item.active {
  opacity: 1;
}

.platform-icon-wrapper {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 8rpx;
  border-radius: 14rpx;
  overflow: hidden;
  border: 1rpx solid rgba(23, 26, 31, 0.08);
  background: #ffffff;
}

.platform-icon {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
}

.status-dot {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #cfd6e2;
  border: 2rpx solid #ffffff;
}

.status-dot.available {
  background: var(--color-accent);
  box-shadow: 0 0 10rpx rgba(0, 194, 168, 0.45);
}

.platform-name {
  font-size: 20rpx;
  color: var(--color-text-body);
}

.platform-item.inactive .platform-name {
  color: var(--color-text-muted);
}

.platform-icons.small .platform-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
}

.platform-icons.small .platform-name {
  font-size: 18rpx;
}

.platform-icons.large .platform-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
}

.platform-icons.large .platform-name {
  font-size: 24rpx;
}
