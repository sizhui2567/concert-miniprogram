/* components/platform-icons/platform-icons.wxss */
.platform-icons {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.platform-item.inactive {
  opacity: 0.35;
  filter: grayscale(100%);
}

.platform-item.active {
  opacity: 1;
  filter: grayscale(0%);
}

.platform-icon-wrapper {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 8rpx;
}

.platform-icon {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.status-dot {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  border: 2rpx solid #fff;
}

.status-dot.available {
  background-color: #4CD964;
}

.platform-name {
  font-size: 20rpx;
  color: #666;
}

.platform-item.inactive .platform-name {
  color: #999;
}

/* 尺寸变体 */
.platform-icons.small .platform-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
}

.platform-icons.small .platform-name {
  font-size: 18rpx;
}

.platform-icons.large .platform-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
}

.platform-icons.large .platform-name {
  font-size: 24rpx;
}
