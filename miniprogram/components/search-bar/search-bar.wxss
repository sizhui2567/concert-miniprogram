/* components/search-bar/search-bar.wxss */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: var(--ng-bg-surface);
}

.search-bar-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: var(--ng-bg-elevated);
  border-radius: 36rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--ng-text-primary);
}

.search-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: var(--ng-text-muted);
}

.placeholder {
  color: var(--ng-text-muted);
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-left: 16rpx;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-bar {
  background: var(--c-151922);
}

.search-bar-inner {
  background: var(--c-1f2733);
  border: 1rpx solid rgba(201, 168, 106, 0.2);
}

.search-input {
  color: var(--c-f5f2ea);
}

.search-placeholder,
.placeholder {
  color: var(--c-b8b4aa);
}
