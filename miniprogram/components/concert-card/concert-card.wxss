/* components/concert-card/concert-card.wxss */
.concert-card {
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.concert-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 海报区域 */
.poster-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.poster {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.stage-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

/* 信息区域 */
.info-wrapper {
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.location,
.date {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.location .icon,
.date .icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.location .text,
.date .text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 平台图标区域 */
.platforms-wrapper {
  margin: 20rpx 0;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 24rpx;
  color: #FF6B6B;
  margin-right: 4rpx;
}

.price-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.btn-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-subscribe,
.btn-detail {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  border: none;
  line-height: 1;
  margin: 0;
}

.btn-subscribe {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
}

.btn-subscribe.subscribed {
  background: #f0f0f0;
  color: #999;
}

.btn-detail {
  background: #f5f5f5;
  color: #666;
}

.btn-subscribe::after,
.btn-detail::after {
  border: none;
}
