/* components/concert-card/concert-card.wxss */
.concert-card {
  margin: 20rpx 24rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(23, 26, 31, 0.06);
  box-shadow: var(--shadow-card);
}

.concert-card:active {
  transform: scale(0.985);
}

.poster-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.poster {
  width: 100%;
  height: 100%;
}

.stage-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.info-wrapper {
  position: relative;
  padding: 22rpx;
}

.info-wrapper::before,
.info-wrapper::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 44rpx);
  border-top: 1rpx dashed #d6dde8;
}

.info-wrapper::before {
  top: 0;
}

.info-wrapper::after {
  display: none;
}

.title {
  font-size: 32rpx;
  line-height: 46rpx;
  font-weight: 600;
  color: var(--color-text-strong);
  margin-bottom: 14rpx;
}

.location,
.date {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-body);
}

.location .icon,
.date .icon {
  margin-right: 8rpx;
}

.location .text,
.date .text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.platforms-wrapper {
  margin: 16rpx 0;
  padding: 14rpx 0;
  border-top: 1rpx dashed #dbe2ec;
  border-bottom: 1rpx dashed #dbe2ec;
}

.action-bar {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.price {
  display: flex;
  align-items: baseline;
  color: var(--color-primary);
}

.price-label {
  font-size: 20rpx;
}

.price-value {
  font-family: var(--ff-number);
  font-size: 34rpx;
  font-weight: 700;
}

.btn-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.btn-subscribe,
.btn-detail {
  margin: 0;
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 16rpx;
  border-radius: 32rpx;
  border: none;
  font-size: 24rpx;
}

.btn-subscribe::after,
.btn-detail::after {
  border: none;
}

.btn-subscribe {
  color: #ffffff;
  background: var(--color-primary);
}

.btn-subscribe.subscribed {
  background: var(--color-accent);
}

.btn-detail {
  color: var(--color-primary);
  background: #fff0ed;
  border: 1rpx solid rgba(255, 90, 54, 0.2);
}
