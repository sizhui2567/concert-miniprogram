/* common.wxss - 公共样式 */

/* 颜色变量 */
page {
  /* Brand */
  --color-primary: #ff5a36;
  --color-accent: #00c2a8;
  --color-warning: #ffb020;
  --color-bg-page: #f7f8fa;
  --color-bg-night: #1a1a1a;
  --color-surface: #ffffff;
  --color-text-strong: #171a1f;
  --color-text-body: #667085;
  --color-text-muted: #99a2b3;
  --color-border: #e5e7eb;

  /* Typography (375px viewport baseline) */
  --fz-h1: 48rpx;
  --lh-h1: 64rpx;
  --fz-h2: 32rpx;
  --lh-h2: 48rpx;
  --fz-body: 28rpx;
  --lh-body: 40rpx;
  --fz-caption: 24rpx;
  --lh-caption: 36rpx;
  --ff-number: 'DIN Alternate', 'DIN', 'SF Pro Display', 'Segoe UI', sans-serif;
  --ff-cjk: 'PingFang SC', 'Noto Sans SC', 'Microsoft YaHei', sans-serif;

  /* Spacing / Radius / Shadow */
  --space-8: 16rpx;
  --space-12: 24rpx;
  --space-16: 32rpx;
  --space-24: 48rpx;
  --radius-card: 32rpx;
  --radius-btn: 24rpx;
  --radius-tag-sm: 8rpx;
  --radius-tag: 16rpx;
  --shadow-card: 0 8rpx 32rpx rgba(23, 26, 31, 0.04);
  --shadow-sticky: 0 -8rpx 48rpx rgba(0, 0, 0, 0.06);

  /* Backward compatible aliases */
  --primary-color: var(--color-primary);
  --secondary-color: var(--color-accent);
  --text-primary: var(--color-text-strong);
  --text-secondary: var(--color-text-body);
  --text-light: var(--color-text-muted);
  --bg-color: var(--color-bg-page);
  --white: var(--color-surface);
  --border-color: var(--color-border);

  /* 阶段颜色 */
  --stage-rumor: var(--c-999999);
  --stage-listed: #3498db;
  --stage-first: #e67e22;
  --stage-second: #e74c3c;
  --stage-third: #9b59b6;
  --stage-ended: #7f8c8d;

  --ng-bg-page: var(--color-bg-page);
  --ng-bg-surface: var(--color-surface);
  --ng-bg-elevated: #f0f2f5;
  --ng-text-primary: var(--color-text-strong);
  --ng-text-secondary: var(--color-text-body);
  --ng-text-muted: var(--color-text-muted);
  --ng-accent: var(--color-primary);
  --ng-accent-strong: #ff7a5b;
  --ng-border: rgba(23, 26, 31, 0.1);

